{
  "buildCommand": "npm run build --workspace @appifylab/shared --workspace @appifylab/web",
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://social-api.efazulkarim.me/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
