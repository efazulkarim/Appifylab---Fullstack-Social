{
  "buildCommand": "npm run build --workspace @appifylab/shared --workspace @appifylab/web",
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.yourvpsdomain.com/api/:path*"
    },
    {
      "source": "/:(?!api)(.*)",
      "destination": "/index.html"
    }
  ]
}
